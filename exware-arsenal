function GetClosestPlayer(FOV)
    local plr
    local Mouse = LocalPlayer:GetMouse()
    local MPos = Mouse.Hit.Position
    local dist = math.huge
    for i,v in Players:GetPlayers() do
        if v.Team ~= LocalPlayer.Team or not CombatSettings.TeamCheck and v ~= LocalPlayer then
            local char = v.Character
            local charpartpos, onscreen = workspace.CurrentCamera:WorldToViewportPoint(char.Head.Position)
            if onscreen then
                local mag = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(charpartpos.X, charpartpos.Y)).Magnitude
                if mag < dist and mag < FOV then
                    dist = mag 
                    plr = v
                end
            end
        end
    end
    return plr, dist
end



