local esp_settings = {
    textsize = 16,  
    colour = Color3.fromRGB(255, 255, 255)  
}
-- found this from my old script lmfao
local espEnabled = false  


local function calculateDistance(point1, point2)
    return (point1 - point2).magnitude
end


local function updateESP(player)
    if espEnabled and player ~= game.Players.LocalPlayer and player.Team ~= game.Players.LocalPlayer.Team then
        local character = player.Character
        if character and character:FindFirstChild("Head") then
            local head = character.Head
            local headPosition = head.Position
            local localPlayerHeadPosition = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character.Head and game.Players.LocalPlayer.Character.Head.Position
            
            if localPlayerHeadPosition then
                local distance = calculateDistance(localPlayerHeadPosition, headPosition)
                
                local existingESP = head:FindFirstChild("CrackedESP")
                if not existingESP then
                    local gui = Instance.new("BillboardGui")
                    gui.Name = "CrackedESP"
                    gui.ResetOnSpawn = false
                    gui.AlwaysOnTop = true
                    gui.Size = UDim2.new(1.75, 0, 1.75, 0)
                    gui.StudsOffset = Vector3.new(0, 3, 0) 
                    gui.Adornee = head
                    
                    local esp = Instance.new("TextLabel", gui)
                    esp.BackgroundTransparency = 1
                    esp.Size = UDim2.new(1, 0, 1, 0)
                    esp.BorderSizePixel = 0
                    esp.Font = Enum.Font.SourceSansBold
                    esp.TextSize = esp_settings.textsize
                    esp.TextColor3 = esp_settings.colour
                    esp.TextStrokeTransparency = 0.5
                    esp.TextStrokeColor3 = Color3.new(0, 0, 0)
                    esp.Text = player.DisplayName .. "\nDistance: " .. math.floor(distance) .. " studs"
                    
                    gui.Parent = head
                else
                    -- Update existing ESP with player display name and distance
                    existingESP.TextLabel.Text = player.DisplayName .. "\nDistance: " .. math.floor(distance) .. " studs"
                end
            end
        end
    else
        local character = player.Character
        if character then
            local head = character:FindFirstChild("Head")
            if head then
                local existingESP = head:FindFirstChild("CrackedESP")
                if existingESP then
                    existingESP:Destroy()
                end
            end
        end
    end
end

local function toggleESP()
    espEnabled = not espEnabled
    if espEnabled then
        for _, player in ipairs(game.Players:GetPlayers()) do
            updateESP(player)
        end
    else
        -- Disable ESP, remove all existing ESPs
        for _, player in ipairs(game.Players:GetPlayers()) do
            local character = player.Character
            if character then
                local head = character:FindFirstChild("Head")
                if head then
                    local existingESP = head:FindFirstChild("CrackedESP")
                    if existingESP then
                        existingESP:Destroy()
                    end
                end
            end
        end
    end
end



