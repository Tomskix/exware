local function checkNoWallsBetween(player1, player2)
    local character1 = player1.Character
    local character2 = player2.Character
    
    if not character1 or not character2 then
        return false
    end
    
    local part1 = character1.PrimaryPart
    local part2 = character2.PrimaryPart
    
    if not part1 or not part2 then
        return false
    end
    

    local direction = (part2.Position - part1.Position).unit
    

    local ray = Ray.new(part1.Position, direction * (part2.Position - part1.Position).magnitude)
    local hitPart, hitPosition = game.Workspace:FindPartOnRay(ray, player1.Character, false, true)
    
    
    if hitPart and hitPart:IsA("BasePart") then
        if hitPart:IsDescendantOf(player1.Character) or hitPart:IsDescendantOf(player2.Character) then
            return true
        end
    end
    
    return false
end

